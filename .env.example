# ============================================================
# SUPABASE (new publishable/secret key format)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Legacy keys (still supported through 2026)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# DATABASE (Prisma direct)
# ============================================================
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# ============================================================
# SUPABASE CLI / MANAGEMENT
# ============================================================
SUPABASE_ACCESS_TOKEN=sb_access_token
SUPABASE_PROJECT_REF=your-project-ref

# ============================================================
# NEXT.JS
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# STORAGE
# ============================================================
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1/object/public

# ============================================================
# EMAIL
# ============================================================
RESEND_API_KEY=re_xxxx

# ============================================================
# STRIPE (billing)
# ============================================================
STRIPE_SECRET_KEY=sk_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxxx

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
